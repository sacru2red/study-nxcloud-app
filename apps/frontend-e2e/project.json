{
  "name": "frontend-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/frontend-e2e/src",
  "tags": [],
  "implicitDependencies": ["frontend", "backend"],
  "// targets": "to see all targets run: nx show project frontend-e2e --web",
  "targets": {
    "e2e": {
      "dependsOn": [{ "projects": "backend", "target": "build" }]
    },
    "capture-demo": {
      "command": "npx playwright test --project=demo-capture",
      "options": {
        "cwd": "apps/frontend-e2e"
      },
      "dependsOn": [{ "projects": "backend", "target": "build" }],
      "inputs": ["default", "^default", "{projectRoot}/**/*.ts"]
    }
  }
}
