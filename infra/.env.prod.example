# Copy to repository root as .env (used by docker-compose.prod.yml)
#   cp infra/.env.prod.example .env

# --- PostgreSQL (docker internal) ---
POSTGRES_USER=nxcloud
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nxcloud_app

# --- Nextcloud (docker internal) ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-nextcloud-admin

# Prisma (backend container overrides host; keep in sync with POSTGRES_*)
DATABASE_URL=postgresql://nxcloud:change-me-strong-password@postgres:5432/nxcloud_app

# --- App secrets ---
JWT_SECRET=change-me-to-random-string
JWT_EXPIRES_IN=24h

# Public URL of the app (OCI VM public IP or domain) — used for CORS
# Example: http://123.45.67.89  or  https://demo.example.com
CORS_ORIGIN=http://YOUR_PUBLIC_IP_OR_DOMAIN

# --- External APIs ---
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional: Gemini failure / 429 → OpenRouter embeddings (768d)
OPENROUTER_API_KEY=
EMBEDDING_FALLBACK_URL=https://openrouter.ai/api/v1/embeddings
EMBEDDING_FALLBACK_MODEL=openai/text-embedding-3-small

LLM_API_KEY=
LLM_MODEL=minimax-m2.5-free

# --- Deploy options ---
HTTP_PORT=80
# Set false after first successful deploy to skip re-seed on restart
RUN_SEED=true
